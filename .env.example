# Anveesa Nias Configuration
# Copy this file to .env and customize for your environment

# ══════════════════════════════════════════════════════════════════════════════
# Environment
# ══════════════════════════════════════════════════════════════════════════════
# Set to "production" for production deployments
NIAS_ENV=development

# ══════════════════════════════════════════════════════════════════════════════
# Server
# ══════════════════════════════════════════════════════════════════════════════
HOST=0.0.0.0
PORT=8080

# Web / Vite dev proxy target
VITE_API_PROXY_TARGET=http://localhost:8080

# ══════════════════════════════════════════════════════════════════════════════
# TLS/HTTPS (recommended for production)
# ══════════════════════════════════════════════════════════════════════════════
TLS_ENABLED=false
TLS_CERT_FILE=/path/to/cert.pem
TLS_KEY_FILE=/path/to/key.pem

# ══════════════════════════════════════════════════════════════════════════════
# Database
# ══════════════════════════════════════════════════════════════════════════════
# Path to SQLite database file
DB_PATH=data.db

# Automatic backup settings
BACKUP_ENABLED=true
BACKUP_DIR=backups
BACKUP_HOURS=24

# ══════════════════════════════════════════════════════════════════════════════
# Security - CHANGE THESE IN PRODUCTION!
# ══════════════════════════════════════════════════════════════════════════════
# JWT secret for authentication (minimum 32 characters in production)
# Generate with: openssl rand -hex 32
JWT_SECRET=<CHANGE_ME_JWT_SECRET_MIN_32_CHARS>

# JWT token expiry in hours
JWT_EXPIRY_HOURS=72

# Enable/disable authentication (set to false only for testing)
AUTH_ENABLED=true

# Encryption key for database credentials (exactly 32 characters)
# Generate with: openssl rand -hex 16
NIAS_ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Default admin account (created on first install if no users exist)
# IMPORTANT: Change these credentials in production!
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=<CHANGE_ME_ADMIN_PASSWORD>

# ══════════════════════════════════════════════════════════════════════════════
# CORS
# ══════════════════════════════════════════════════════════════════════════════
# Comma-separated list of allowed origins
# Use specific origins in production, not "*"
CORS_ORIGIN=http://localhost:5173

# ══════════════════════════════════════════════════════════════════════════════
# Rate Limiting
# ══════════════════════════════════════════════════════════════════════════════
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ══════════════════════════════════════════════════════════════════════════════
# Logging
# ══════════════════════════════════════════════════════════════════════════════
# Log level: debug, info, warn, error
LOG_LEVEL=info
# Log format: text, json
LOG_FORMAT=text
