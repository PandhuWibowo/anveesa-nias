# Anveesa Nias - PostgreSQL Configuration
# Copy this file to .env for PostgreSQL deployment

# ══════════════════════════════════════════════════════════════════════════════
# Environment
# ══════════════════════════════════════════════════════════════════════════════
NIAS_ENV=production

# ══════════════════════════════════════════════════════════════════════════════
# Server
# ══════════════════════════════════════════════════════════════════════════════
PORT=8080

# Web / Vite API proxy target
VITE_API_PROXY_TARGET=http://localhost:8080

# ══════════════════════════════════════════════════════════════════════════════
# Database - PostgreSQL
# ══════════════════════════════════════════════════════════════════════════════
# PostgreSQL connection details
POSTGRES_DB=nias
POSTGRES_USER=nias
POSTGRES_PASSWORD=your-secure-postgres-password-here

# Database driver (postgres or sqlite)
DB_DRIVER=postgres

# Full PostgreSQL connection URL (auto-generated from above if using docker-compose.postgres.yml)
# Format: postgres://user:password@host:port/database?sslmode=disable
# DATABASE_URL=postgres://nias:password@localhost:5432/nias?sslmode=disable

# ══════════════════════════════════════════════════════════════════════════════
# Security - CHANGE THESE IN PRODUCTION!
# ══════════════════════════════════════════════════════════════════════════════
# JWT secret for authentication (minimum 32 characters)
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secure-jwt-secret-min-32-chars-here

# JWT token expiry in hours
JWT_EXPIRY_HOURS=72

# Enable/disable authentication
AUTH_ENABLED=true

# Encryption key for database credentials (exactly 32 characters)
# Generate with: openssl rand -hex 16
NIAS_ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Default admin account (created on first install if no users exist)
# IMPORTANT: Change these credentials!
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=YourSecurePassword123!

# ══════════════════════════════════════════════════════════════════════════════
# CORS
# ══════════════════════════════════════════════════════════════════════════════
# Comma-separated list of allowed origins (use * for all origins in development only)
CORS_ORIGIN=https://yourdomain.com

# ══════════════════════════════════════════════════════════════════════════════
# Rate Limiting
# ══════════════════════════════════════════════════════════════════════════════
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ══════════════════════════════════════════════════════════════════════════════
# Logging
# ══════════════════════════════════════════════════════════════════════════════
LOG_LEVEL=info
LOG_FORMAT=text
